#!/usr/bin/env bash
# Force-remove all git worktrees whose branch has been merged (incl. squash) into main.
# Uses three detection strategies:
#   1. git merge-base --is-ancestor (regular merge)
#   2. GitHub API via gh (squash/rebase merges — authoritative)
#   3. commit-tree + cherry patch-id (offline fallback)
set -euo pipefail

git fetch --prune origin

# Determine the GitHub remote owner/repo for gh api calls
gh_repo=$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null) || gh_repo=""

merged_branches=$(git branch --format='%(refname:short)' | grep -v '^main$' | while read -r b; do
  # Strategy 1: regular merge — branch tip is ancestor of origin/main
  if git merge-base --is-ancestor "$b" origin/main 2>/dev/null; then
    echo "$b"
    continue
  fi

  # Strategy 2: ask GitHub whether any merged PR exists for this branch
  if [ -n "$gh_repo" ]; then
    pr_state=$(gh pr list --repo "$gh_repo" --head "$b" --state merged --json number --jq '.[0].number' 2>/dev/null) || pr_state=""
    if [ -n "$pr_state" ]; then
      echo "$b"
      continue
    fi
  fi

  # Strategy 3: synthetic squash commit + patch-id comparison (offline fallback)
  merge_base=$(git merge-base origin/main "$b" 2>/dev/null) || continue
  tree=$(git rev-parse "${b}^{tree}" 2>/dev/null) || continue
  squash_commit=$(git commit-tree "$tree" -p "$merge_base" -m _) || continue
  if git cherry origin/main "$squash_commit" 2>/dev/null | grep -q '^-'; then
    echo "$b"
  fi
done || true)

if [ -z "$merged_branches" ]; then
  echo "No merged branches found."
  exit 0
fi

removed=0
wt_path="" wt_branch=""

while IFS= read -r line; do
  case "$line" in
    "worktree "*)  wt_path="${line#worktree }" ;;
    "branch "*)    wt_branch="${line#branch refs/heads/}" ;;
    "")
      if [ -n "$wt_branch" ] && echo "$merged_branches" | grep -qx "$wt_branch"; then
        echo "Removing worktree: $wt_path (branch: $wt_branch)"
        git worktree remove --force "$wt_path"
        git branch -D "$wt_branch" 2>/dev/null || true
        ((++removed))
      fi
      wt_path="" wt_branch=""
      ;;
  esac
done < <(git worktree list --porcelain && echo "")

if [ "$removed" -eq 0 ]; then
  echo "No worktrees to clean up."
else
  echo "Removed $removed worktree(s)."
fi
